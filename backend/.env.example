# Neon PostgreSQL
# Get DATABASE_URL_UNPOOLED from Neon console (needed for transactions)
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:npg_...@ep-...neon.tech/neondb?sslmode=require

# Pooled URL (optional, for non-transaction queries)
DATABASE_URL=postgresql://neondb_owner:npg_...@ep-...neon.tech/neondb?sslmode=require

# Server
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# NextAuth secret (same as frontend .env)
AUTH_SECRET=your-secret-here

# Environment
NODE_ENV=development
