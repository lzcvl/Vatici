# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Pooled connection — used by the backend API (Railway)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Unpooled connection — used by the Next.js frontend for auth queries only
DATABASE_URL_UNPOOLED=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Production URL — required for NextAuth callbacks and cookie domain
AUTH_URL=https://vatici.com

# ─── Backend API ───────────────────────────────────────────────────────────────
# URL of the Railway backend (Hono API)
NEXT_PUBLIC_API_URL=https://your-app.railway.app

# ─── App URL ───────────────────────────────────────────────────────────────────
# Used for OG image generation and canonical links
NEXT_PUBLIC_APP_URL=https://vatici.com

# ─── Cloudflare Turnstile (optional — CAPTCHA on login/signup) ────────────────
# Create a site at https://dash.cloudflare.com → Turnstile
# Leave empty to disable CAPTCHA (development mode)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
